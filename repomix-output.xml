# VCDesign Protocol: Judgment Closure
# Purpose: Define the procedure for "closing" a judgment (ending the infinite regress).

id: "vcdesign-protocol-judgment-closure"
title: "Judgment Closure Protocol"
layer: "protocol"
status: "stable"
version: "2.1.0"

meta:
  goal: "Explicitly sign, deny, or declare unknown for a specific judgment proposal."
  role: "The gate to Responsibility."
  context: "Occurs at an 'Explicit Verification Point' (also known as a Closure Point or Boundary)."

preconditions:
  - "Responsibility Closure Loop (RCL) is defined and Δ is assigned to R before closure."

# -------------------------------------------------------------------
# Input Contract

# -------------------------------------------------------------------
input:
  required_fields:
    - facts: "Immutable facts upon which judgment is based."
    - proposal: "The specific decision content to be signed."
    - context: "Context traces (optional)."

# -------------------------------------------------------------------
# Output States (The Closure)
# -------------------------------------------------------------------
output:
  states:
    ACCEPTED:
      meaning: "Responsibility is accepted."
      requirement: "Must include a valid signature/owner."
      next_action: "Promotable to Resolution."
      
    DENIED:
      meaning: "Responsibility is refused."
      requirement: "Must include a reason."
      next_action: "Stop. Do not proceed."
      
    UNKNOWN:
      meaning: "Cannot determine."
      requirement: "Must include a reason."
      next_action: "Escalate to higher authority or fallback (Fail-Safe)."

# -------------------------------------------------------------------
# Invariants
# -------------------------------------------------------------------
invariants:
  - "No closure without explicit state."
  - "ACCEPTED state effectively creates a 'Responsibility Asset'."
  - "UNKNOWN must effectively pause the flow (never treat as yes)."
</file>

<file path="specs/protocols/resolution-handshake.yaml">
# VCDesign Protocol: Resolution Handshake
# Purpose: Define how a "Closed Judgment" becomes a "Resolution" (a committed Action).
# Formerly: "Resolution Protocol (RP)" and "CCP Handshake"

id: "vcdesign-protocol-resolution-handshake"
title: "Resolution Handshake Protocol"
layer: "protocol"
status: "stable"
version: "2.1.0"

meta:
  goal: "Promote a Closed Judgment to a Resolution (Responsibility Commitment)."
  role: "The bridge between Meaning (Judgment) and Action (Resolution)."

# -------------------------------------------------------------------
# Constitutional Definition
# -------------------------------------------------------------------
constitutional_role:
  - "Close decision loops"
  - "Enable revision, rollback, or termination"

# RP is NOT "how to decide".
# RP IS "how not to break the value chain after deciding".

constitution_compliance:
  VC-G-003: "RP ensures every decision belongs to a closed loop."
  termination_principle: "RP provides the path for Proper Termination."
  chapter_model: "RP signals the completion of a Chapter."

# -------------------------------------------------------------------
# Prerequisite
# -------------------------------------------------------------------
prerequisite:
  - "Judgment Closure must be ACCEPTED."
  - "Responsible Actor must be identified."

# -------------------------------------------------------------------
# The Handshake Schema (Interaction Model)
# -------------------------------------------------------------------
handshake_schema:
  internal_promotion:
    description: "When judgment and resolution happen within one trusted boundary."
    steps:
      1. Verify Closure == ACCEPTED.
      2. Verify Responsible Actor exists.
      3. Commit Resolution Record.

  external_handshake:
    description: "When judgment provider and resolution consumer are different."
    refers_to: "Content Continuity Protocol (CCP)"
    required_fields:
      - "handshake_meta (id, nonce, timestamp)"
      - "continuity_claim (the guarantee)"
      - "signature (the proof)"

# -------------------------------------------------------------------
# Output (The Resolution)
# -------------------------------------------------------------------
resolution_object:
  definition: "A committed unit of responsibility."
  required_fields:
    - resolution_id
    - responsible_actor
    - scope
    - expiry (time-bound)
    - trace_reference (provenance)

# -------------------------------------------------------------------
# Routing (When Handshake Fails)
# -------------------------------------------------------------------
routing_on_failure:
  - return_to_human: "Escalate to a human operator."
  - quarantine: "Isolate the judgment as unsafe."
  - deny: "Reject the action completely."
</file>

