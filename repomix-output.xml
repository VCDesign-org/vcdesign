# specs/boundaries/data-meaning.yaml
meta:
  id: CASE-DATA-MEANING
  title: Data Meaning Case
  layer: boundaries
  status: draft
  version: 0.1.0

boundary:
  description: >
    A case study where AI output lacks semantic context, preventing
    human judgment and violating the B4 (Data ↔ Meaning) boundary.

  canonical_scenarios:
    - Defect detection AI returns classification results
      without exposing reasons, confidence, or supporting evidence,
      preventing humans from forming actionable meaning.

  failure_modes:
    - AI outputs results without semantic explanation.
    - Humans cannot explain or justify AI-based judgments.
    - Final judgment responsibility stalls or disappears.

  missing_elements_observed:
    - No explanation artifacts for AI judgments.
    - No shared interpretive frame between AI and humans.
    - No closure point for "is this judgment explainable enough to proceed".

  recommended_handling:
    decision_posture: defer
    rationale: >
      Judgments without shared meaning
      cannot be responsibly owned by humans.
    protocols:
      - judgment-closure
    patterns:
      - boundary-pattern
      - rca-pattern

  expiry_and_revisit:
    required: true
    typical_expiry: "upon model update or domain shift"

references:
  chapters:
    - ../chapters/c3-trust-erosion.yaml
</file>

<file path="specs/boundaries/impact-accountability.yaml">
# specs/boundaries/impact-accountability.yaml
meta:
  id: B17
  title: Impact ↔ Accountability Boundary
  layer: boundaries
  status: draft
  version: 0.1.0

boundary:
  description: >
    The boundary that aligns the scope and magnitude of a system's impact
    with clearly assigned responsibility and decision authority.

  typical_triggers:
    - Expansion of optimization or decision scope.
    - Cross-departmental or organizational effects.
    - Automation influencing strategic or managerial decisions.

  failure_modes:
    - Impact grows beyond the authority of the original owner.
    - Responsibility becomes diffused or contested.
    - Decisions continue without a clear accountable actor.

  default_posture:
    decision_posture: defer
    rationale: >
      Decisions whose impact exceeds accountable authority
      must not proceed without explicit re-assignment of responsibility.

  recommended_handling:
    protocols:
      - judgment-closure
      - resolution-handshake
    patterns:
      - boundary-pattern
      - rca-pattern

  monitoring_signals:
    - Increase in affected stakeholders or departments.
    - Escalation paths becoming unclear or informal.
    - Disputes over who should decide or intervene.

  expiry_and_revisit:
    required: true
    typical_expiry: "upon scope expansion or organizational change"

references:
  chapters:
    - ../chapters/c4-reality-drift.yaml
</file>

