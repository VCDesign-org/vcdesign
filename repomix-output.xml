<file path="specs/patterns/rca-pattern.yaml">
# VCDesign Pattern: RCA Structure
# Purpose: Define the standard internal structure of a Responsibility Closure Agent.

id: "vcdesign-pattern-rca"
title: "RCA Structural Pattern"
layer: "pattern"
status: "stable"
version: "2.1.0"

meta:
  role: "The active judge at the boundary."
  implements: "vcdesign-protocol-judgment-closure"


preconditions:
  - "Responsibility Closure Loop (RCL) is defined and operational."
notes:
  - "RCA does not substitute RCL. RCA assumes responsibility only after Δ is assigned to R."

# -------------------------------------------------------------------
# Constitutional Definition

# -------------------------------------------------------------------
constitutional_role:
  - "Anchor responsibility for a decision"
  - "Prevent responsibility diffusion"
  - "Enable explicit acceptance or rejection"

prohibitions:
  - "MUST NOT select the 'optimal' solution (Optimization is not Judgment)."
  - "MUST NOT guarantee correctness (Responsibility is about owning failure)."
  - "MUST NOT define value (Value is defined by the context/human)."

constitution_compliance:
  VC-A-001: "RCA makes the judgment point explicit."
  VC-A-002: "RCA names the specific subject of responsibility."
  VC-G-001: "Any decision without an RCA is invalid."
  VC-R-003: "RCA explicitly refuses automated/externalized responsibility."

# -------------------------------------------------------------------
# Internal Components
# -------------------------------------------------------------------
components:
  policy_engine:
    role: "Evaluates Facts against Criteria."
    inputs: ["Facts", "Judgment Proposal"]
    outputs: ["Pass/Fail/Unknown"]
    
  signer:
    role: "Attaches cryptographic or authoritative signature."
    condition: "Only signs if Policy Engine returns Pass."
    
  auditor:
    role: "Records the transaction (Trace)."
    requirement: "Must log Denials as well as acceptances."

# -------------------------------------------------------------------
# Configuration Pattern
# -------------------------------------------------------------------
configuration:
  risk_tolerance:
    enum: ["strict", "permissive", "learning"]
    default: "strict"
    
  fallback_strategy:
    enum: ["deny_all", "escalate_to_human", "defer"]
    default: "deny_all"

# -------------------------------------------------------------------
# Implementation Guidelines
# -------------------------------------------------------------------
guidelines:
  - "The RCA should be isolated from the 'Solver' logic (don't mix generation and judgment)."
  - "The RCA must be stateless regarding the 'content' generation, but stateful regarding 'responsibility' history."
</file>

